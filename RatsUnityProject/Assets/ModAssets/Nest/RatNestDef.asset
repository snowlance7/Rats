%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 608100558, guid: 1f73291e6cf64124796e048d841e7d1f, type: 3}
  m_Name: RatNestDef
  m_EditorClassIdentifier: 
  _configEntries:
  - settingName: Max Rats
    DynamicConfigType: 1
    defaultString: 
    defaultInt: 50
    defaultFloat: 0
    defaultBool: 0
    defaultBoundedRange:
      <Min>k__BackingField: 5
      <Max>k__BackingField: 20
    defaultAnimationCurve:
      serializedVersion: 2
      m_Curve: []
      m_PreInfinity: 0
      m_PostInfinity: 0
      m_RotationOrder: 0
    defaultVector3: {x: 0, y: 0, z: 0}
    defaultColor: {r: 0, g: 0, b: 0, a: 0}
    Description: The maximum number of rats that can be on the map. Lowering this
      can improve performance.
  - settingName: Batch Group Count
    DynamicConfigType: 1
    defaultString: 
    defaultInt: 5
    defaultFloat: 0
    defaultBool: 0
    defaultBoundedRange:
      <Min>k__BackingField: 5
      <Max>k__BackingField: 20
    defaultAnimationCurve:
      serializedVersion: 2
      m_Curve: []
      m_PreInfinity: 0
      m_PostInfinity: 0
      m_RotationOrder: 0
    defaultVector3: {x: 0, y: 0, z: 0}
    defaultColor: {r: 0, g: 0, b: 0, a: 0}
    Description: The amount of groups the rats will be split into to update. (if
      you dont know what this means, just leave this config alone)
  - settingName: Batch Update Interval
    DynamicConfigType: 2
    defaultString: 
    defaultInt: 10
    defaultFloat: 0.2
    defaultBool: 0
    defaultBoundedRange:
      <Min>k__BackingField: 5
      <Max>k__BackingField: 20
    defaultAnimationCurve:
      serializedVersion: 2
      m_Curve: []
      m_PreInfinity: 0
      m_PostInfinity: 0
      m_RotationOrder: 0
    defaultVector3: {x: 0, y: 0, z: 0}
    defaultColor: {r: 0, g: 0, b: 0, a: 0}
    Description: The amount of time between each group update. (if you dont know
      what this means, just leave this config alone)
  - settingName: Rat Spawn Time
    DynamicConfigType: 4
    defaultString: 
    defaultInt: 0
    defaultFloat: 0
    defaultBool: 0
    defaultBoundedRange:
      <Min>k__BackingField: 5
      <Max>k__BackingField: 20
    defaultAnimationCurve:
      serializedVersion: 2
      m_Curve: []
      m_PreInfinity: 0
      m_PostInfinity: 0
      m_RotationOrder: 0
    defaultVector3: {x: 0, y: 0, z: 0}
    defaultColor: {r: 0, g: 0, b: 0, a: 0}
    Description: The min/max time in seconds before a rat can spawn from a nest after
      the last rat was spawned
  - settingName: Food Required to Spawn Rat
    DynamicConfigType: 1
    defaultString: 
    defaultInt: 5
    defaultFloat: 0
    defaultBool: 0
    defaultBoundedRange:
      <Min>k__BackingField: 5
      <Max>k__BackingField: 20
    defaultAnimationCurve:
      serializedVersion: 2
      m_Curve: []
      m_PreInfinity: 0
      m_PostInfinity: 0
      m_RotationOrder: 0
    defaultVector3: {x: 0, y: 0, z: 0}
    defaultColor: {r: 0, g: 0, b: 0, a: 0}
    Description: The amount of food needed in the nest to spawn a new rat
  - settingName: Food Per HP Point
    DynamicConfigType: 1
    defaultString: 
    defaultInt: 10
    defaultFloat: 0
    defaultBool: 0
    defaultBoundedRange:
      <Min>k__BackingField: 5
      <Max>k__BackingField: 20
    defaultAnimationCurve:
      serializedVersion: 2
      m_Curve: []
      m_PreInfinity: 0
      m_PostInfinity: 0
      m_RotationOrder: 0
    defaultVector3: {x: 0, y: 0, z: 0}
    defaultColor: {r: 0, g: 0, b: 0, a: 0}
    Description: 'How much food points one HP will equal for enemies. ex: if 10,
      thumper will give 40 food points'
  - settingName: Holiday Rats
    DynamicConfigType: 3
    defaultString: 
    defaultInt: 10
    defaultFloat: 0
    defaultBool: 0
    defaultBoundedRange:
      <Min>k__BackingField: 5
      <Max>k__BackingField: 20
    defaultAnimationCurve:
      serializedVersion: 2
      m_Curve: []
      m_PreInfinity: 0
      m_PostInfinity: 0
      m_RotationOrder: 0
    defaultVector3: {x: 0, y: 0, z: 0}
    defaultColor: {r: 0, g: 0, b: 0, a: 0}
    Description: Rats spawn with a santa hat
  - settingName: Use Jerma Rats
    DynamicConfigType: 3
    defaultString: 
    defaultInt: 10
    defaultFloat: 0
    defaultBool: 0
    defaultBoundedRange:
      <Min>k__BackingField: 5
      <Max>k__BackingField: 20
    defaultAnimationCurve:
      serializedVersion: 2
      m_Curve: []
      m_PreInfinity: 0
      m_PostInfinity: 0
      m_RotationOrder: 0
    defaultVector3: {x: 0, y: 0, z: 0}
    defaultColor: {r: 0, g: 0, b: 0, a: 0}
    Description: Uses a lower quality model for the rats with no animations. Can
      help with performance if enabled.
  - settingName: Threat to Attack Player
    DynamicConfigType: 1
    defaultString: 
    defaultInt: 100
    defaultFloat: 0
    defaultBool: 0
    defaultBoundedRange:
      <Min>k__BackingField: 5
      <Max>k__BackingField: 20
    defaultAnimationCurve:
      serializedVersion: 2
      m_Curve: []
      m_PreInfinity: 0
      m_PostInfinity: 0
      m_RotationOrder: 0
    defaultVector3: {x: 0, y: 0, z: 0}
    defaultColor: {r: 0, g: 0, b: 0, a: 0}
    Description: The threat level at which rats begin attacking the player
  - settingName: High Player Threat
    DynamicConfigType: 1
    defaultString: 
    defaultInt: 200
    defaultFloat: 0
    defaultBool: 0
    defaultBoundedRange:
      <Min>k__BackingField: 5
      <Max>k__BackingField: 20
    defaultAnimationCurve:
      serializedVersion: 2
      m_Curve: []
      m_PreInfinity: 0
      m_PostInfinity: 0
      m_RotationOrder: 0
    defaultVector3: {x: 0, y: 0, z: 0}
    defaultColor: {r: 0, g: 0, b: 0, a: 0}
    Description: The threat level at which rats will form kill squads to attack players
  - settingName: Threat to Attack Enemy
    DynamicConfigType: 1
    defaultString: 
    defaultInt: 50
    defaultFloat: 0
    defaultBool: 0
    defaultBoundedRange:
      <Min>k__BackingField: 5
      <Max>k__BackingField: 20
    defaultAnimationCurve:
      serializedVersion: 2
      m_Curve: []
      m_PreInfinity: 0
      m_PostInfinity: 0
      m_RotationOrder: 0
    defaultVector3: {x: 0, y: 0, z: 0}
    defaultColor: {r: 0, g: 0, b: 0, a: 0}
    Description: The threat level at which rats begin attacking other enemies
  - settingName: Swarm Radius
    DynamicConfigType: 2
    defaultString: 
    defaultInt: 10
    defaultFloat: 3
    defaultBool: 0
    defaultBoundedRange:
      <Min>k__BackingField: 5
      <Max>k__BackingField: 20
    defaultAnimationCurve:
      serializedVersion: 2
      m_Curve: []
      m_PreInfinity: 0
      m_PostInfinity: 0
      m_RotationOrder: 0
    defaultVector3: {x: 0, y: 0, z: 0}
    defaultColor: {r: 0, g: 0, b: 0, a: 0}
    Description: The radius in which rats swarm around their target
  - settingName: Maximum Defense Rats
    DynamicConfigType: 1
    defaultString: 
    defaultInt: 10
    defaultFloat: 0
    defaultBool: 0
    defaultBoundedRange:
      <Min>k__BackingField: 5
      <Max>k__BackingField: 20
    defaultAnimationCurve:
      serializedVersion: 2
      m_Curve: []
      m_PreInfinity: 0
      m_PostInfinity: 0
      m_RotationOrder: 0
    defaultVector3: {x: 0, y: 0, z: 0}
    defaultColor: {r: 0, g: 0, b: 0, a: 0}
    Description: The maximum number of defense rats assigned to protect the nest
  - settingName: Enemy Hits to Do Damage
    DynamicConfigType: 1
    defaultString: 
    defaultInt: 10
    defaultFloat: 0
    defaultBool: 0
    defaultBoundedRange:
      <Min>k__BackingField: 5
      <Max>k__BackingField: 20
    defaultAnimationCurve:
      serializedVersion: 2
      m_Curve: []
      m_PreInfinity: 0
      m_PostInfinity: 0
      m_RotationOrder: 0
    defaultVector3: {x: 0, y: 0, z: 0}
    defaultColor: {r: 0, g: 0, b: 0, a: 0}
    Description: The amount of attacks needed to do 1 shovel hit of damage to an
      enemy. If 10, thumper will need to be attacked 40 times by a rat.
  - settingName: Player Food Amount
    DynamicConfigType: 1
    defaultString: 
    defaultInt: 30
    defaultFloat: 0
    defaultBool: 0
    defaultBoundedRange:
      <Min>k__BackingField: 5
      <Max>k__BackingField: 20
    defaultAnimationCurve:
      serializedVersion: 2
      m_Curve: []
      m_PreInfinity: 0
      m_PostInfinity: 0
      m_RotationOrder: 0
    defaultVector3: {x: 0, y: 0, z: 0}
    defaultColor: {r: 0, g: 0, b: 0, a: 0}
    Description: How much food points a player corpse gives when brought to the nest
  - settingName: Squeak Chance
    DynamicConfigType: 2
    defaultString: 
    defaultInt: 10
    defaultFloat: 0.01
    defaultBool: 0
    defaultBoundedRange:
      <Min>k__BackingField: 5
      <Max>k__BackingField: 20
    defaultAnimationCurve:
      serializedVersion: 2
      m_Curve: []
      m_PreInfinity: 0
      m_PostInfinity: 0
      m_RotationOrder: 0
    defaultVector3: {x: 0, y: 0, z: 0}
    defaultColor: {r: 0, g: 0, b: 0, a: 0}
    Description: The chance a rat will squeak when completing a run cycle (every
      second)
  - settingName: Rats Take Player Corpses
    DynamicConfigType: 3
    defaultString: 
    defaultInt: 10
    defaultFloat: 0
    defaultBool: 1
    defaultBoundedRange:
      <Min>k__BackingField: 5
      <Max>k__BackingField: 20
    defaultAnimationCurve:
      serializedVersion: 2
      m_Curve: []
      m_PreInfinity: 0
      m_PostInfinity: 0
      m_RotationOrder: 0
    defaultVector3: {x: 0, y: 0, z: 0}
    defaultColor: {r: 0, g: 0, b: 0, a: 0}
    Description: If this is true, allows rats to drag players to their nest to eat
  - settingName: Enable Infestation System
    DynamicConfigType: 3
    defaultString: 
    defaultInt: 10
    defaultFloat: 0
    defaultBool: 1
    defaultBoundedRange:
      <Min>k__BackingField: 5
      <Max>k__BackingField: 20
    defaultAnimationCurve:
      serializedVersion: 2
      m_Curve: []
      m_PreInfinity: 0
      m_PostInfinity: 0
      m_RotationOrder: 0
    defaultVector3: {x: 0, y: 0, z: 0}
    defaultColor: {r: 0, g: 0, b: 0, a: 0}
    Description: Enables the infestation system
